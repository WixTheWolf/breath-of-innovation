{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/mystery",
      "destination": "/map",
      "permanent": false
    },
    {
      "source": "/presentation",
      "destination": "/present",
      "permanent": false
    },
    {
      "source": "/speaker-packet",
      "destination": "/packet",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
